{% layout "layouts/base" %}

{% block title %}We are getting married{% endblock %}

{% block content %}
  <section class="grid">
    <div class="display-flex flex-direction-column justify-content-center text-align-center" style="--grid-column: 1 / 12; --grid-column-md: 1 / 5;">
      <hgroup class="margin-bottom-s">
        <h1 class="margin-bottom-m text-fancy font-size-6">We are getting married</h1>
        <p class="font-size-5">Jon & Gabriella</p>
      </hgroup>
      <time datetime="24-05-2025" class="margin-bottom-s font-size-1 text-transform-uppercase">May 24th, 2025</time>
